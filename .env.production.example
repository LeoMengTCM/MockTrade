# Database
DATABASE_NAME=mocktrade
DATABASE_USER=postgres
DATABASE_PASSWORD=your-strong-password-here

# JWT
JWT_SECRET=your-very-long-random-jwt-secret-at-least-32-chars

# Admin
ADMIN_EMAIL=your-admin@email.com

# AI (optional, fallback to templates if not set)
AI_PROVIDER=openai
AI_API_BASE=https://api.openai.com/v1
AI_API_KEY=sk-your-key
AI_MODEL=gpt-4o
AI_REQUEST_TIMEOUT_MS=15000
AI_MAX_RETRIES=2
AI_RETRY_BASE_DELAY_MS=800

# Frontend URLs
# Leave NEXT_PUBLIC_API_URL / NEXT_PUBLIC_WS_URL empty when using nginx on the same domain.
# Set them explicitly only if the frontend needs to call another host.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
CORS_ORIGIN=http://YOUR_VPS_IP

# Source-build base images / registries
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
NODE_IMAGE=node:20-alpine
NGINX_IMAGE=nginx:alpine
PNPM_REGISTRY=https://registry.npmmirror.com

# Prebuilt app images (used by docker-compose.dockerhub.yml)
MOCKTRADE_SERVER_IMAGE=drleomeng/mocktrade-server:v0.1.1
MOCKTRADE_WEB_IMAGE=drleomeng/mocktrade-web:v0.1.1
MOCKTRADE_NGINX_IMAGE=drleomeng/mocktrade-nginx:v0.1.1

# Optional: domestic mirror examples
# POSTGRES_IMAGE=docker.m.daocloud.io/library/postgres:16-alpine
# REDIS_IMAGE=docker.m.daocloud.io/library/redis:7-alpine
# NODE_IMAGE=docker.m.daocloud.io/library/node:20-alpine
# NGINX_IMAGE=docker.m.daocloud.io/library/nginx:alpine
# MOCKTRADE_SERVER_IMAGE=docker.m.daocloud.io/drleomeng/mocktrade-server:v0.1.1
# MOCKTRADE_WEB_IMAGE=docker.m.daocloud.io/drleomeng/mocktrade-web:v0.1.1
# MOCKTRADE_NGINX_IMAGE=docker.m.daocloud.io/drleomeng/mocktrade-nginx:v0.1.1
