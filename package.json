{
  "name": "mocktrade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server start:dev",
    "build": "pnpm -r run build",
    "build:web": "pnpm --filter web build",
    "build:server": "pnpm --filter server build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "seed": "pnpm --filter server seed",
    "migration:generate": "pnpm --filter server migration:generate",
    "migration:run": "pnpm --filter server migration:run"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  }
}
