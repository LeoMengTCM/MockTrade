# Database
DATABASE_NAME=mocktrade
DATABASE_USER=postgres
DATABASE_PASSWORD=your-strong-password-here

# JWT
JWT_SECRET=your-very-long-random-jwt-secret-at-least-32-chars

# Admin
ADMIN_EMAIL=your-admin@email.com

# AI (optional, fallback to templates if not set)
AI_PROVIDER=openai
AI_API_BASE=https://api.openai.com/v1
AI_API_KEY=sk-your-key
AI_MODEL=gpt-4o
AI_REQUEST_TIMEOUT_MS=15000
AI_MAX_RETRIES=2
AI_RETRY_BASE_DELAY_MS=800

# Frontend URLs (change to your domain or VPS IP)
# If using default ports, the entry point is :9500
NEXT_PUBLIC_API_URL=http://YOUR_VPS_IP:9500
NEXT_PUBLIC_WS_URL=http://YOUR_VPS_IP:9500
CORS_ORIGIN=http://YOUR_VPS_IP:9500

# Host port mapping (defaults below, override as needed)
# NGINX_PORT=9500
# WEB_PORT=9510
# SERVER_PORT=9511
# POSTGRES_PORT=9532
# REDIS_PORT=9579
